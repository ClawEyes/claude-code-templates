---
import NavItem from './NavItem.astro';
import { NAV_LINKS } from '../lib/constants';
import { TYPE_CONFIG, ICONS } from '../lib/icons';
import AuthButton from './AuthButton';
import MyComponentsSidebarItem from './MyComponentsSidebarItem';

const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<div class="flex flex-col h-full p-4 bg-background-primary text-text-primary overflow-y-auto">
  <a href="/" class="flex items-center gap-2 mb-8">
    <img src="/logo.png" alt="AI Templates" class="w-8 h-8" />
    <span class="font-bold text-xl">AI Templates</span>
    <span class="text-xs bg-accent text-background-primary px-2 py-1 rounded-full ml-2">Beta</span>
  </a>

  <div class="mb-6">
    <h3 class="text-xs font-semibold text-text-tertiary uppercase mb-2">Workplace</h3>
    <MyComponentsSidebarItem />
  </div>

  <div class="mb-6">
    <h3 class="text-xs font-semibold text-text-tertiary uppercase mb-2">Browse</h3>
    {Object.entries(TYPE_CONFIG).map(([type, config]) => (
      <NavItem
        href={`/${type}`}
        icon={ICONS[type]}
        label={config.label}
        count={config.count}
        isActive={isActive(`/${type}`)}
      />
    ))}
  </div>

  <div class="mt-auto">
    <h3 class="text-xs font-semibold text-text-tertiary uppercase mb-2">Resources</h3>
    <NavItem href="/trending" label="Trending" icon="trending" />
    <a href={NAV_LINKS.blog} class="flex items-center gap-2 py-2 text-text-tertiary hover:text-text-secondary transition-colors">
      <span class="inline-flex [&>svg]:w-4 [&>svg]:h-4" set:html={ICONS.blog} />
      Blog
    </a>
    <a href={NAV_LINKS.docs} class="flex items-center gap-2 py-2 text-text-tertiary hover:text-text-secondary transition-colors">
      <span class="inline-flex [&>svg]:w-4 [&>svg]:h-4" set:html={ICONS.docs} />
      Docs
    </a>

    <!-- Tambahan: GitHub dan X berdampingan (sebelah kanan) -->
    <div class="flex items-center gap-6 py-2">
      <a href={NAV_LINKS.github} class="flex items-center gap-2 text-text-tertiary hover:text-text-secondary transition-colors">
        <span class="inline-flex [&>svg]:w-4 [&>svg]:h-4" set:html={ICONS.github} />
        GitHub
      </a>
      <a 
        href="https://x.com/ClaudeCodet" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="flex items-center gap-2 text-text-tertiary hover:text-blue-400 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        X
      </a>
    </div>
  </div>

  <AuthButton client:load />
</div>
